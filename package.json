{
  "name": "vecta.co.jp",
  "version": "2025.5.18",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/types": "19.8.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.69.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/bun": "1.3.14",
    "lefthook": "1.11.13",
    "marked": "18.0.6",
    "scaffdog": "4.1.0",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "bun test --pass-with-no-tests",
    "clean": "git clean -xdf node_modules dist .svelte-kit",
    "scaffold": "scaffdog",
    "format": "biome format --write .",
    "check": "biome check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && bun run test",
    "check:fix": "biome check --write"
  },
  "type": "module"
}
